document.getElementById("ctl00_ContentPlaceHolder1_txtPassT2").value == "555555" || 
document.getElementById("ctl00_ContentPlaceHolder1_txtPassT2").value == "666666" || 
document.getElementById("ctl00_ContentPlaceHolder1_txtPassT2").value == "777777" || 
document.getElementById("ctl00_ContentPlaceHolder1_txtPassT2").value == "888888" || 
document.getElementById("ctl00_ContentPlaceHolder1_txtPassT2").value == "999999"){
alert ("Senha  Inválida!");
